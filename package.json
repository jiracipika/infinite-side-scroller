{
  "name": "dashverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "mobile:dev": "npm --prefix apps/mobile run start",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:web": "npm --prefix apps/mobile run web",
    "verify:game": "node scripts/verify-game-content.mjs",
    "verify:multiplayer": "node scripts/verify-multiplayer-config.mjs",
    "verify": "npm run verify:game && npm run verify:multiplayer && npm run verify:multiplayer-api && npm run verify:progression && npm run verify:achievements && npm run verify:saves && npm run verify:hud && npm run verify:mobile && npm run verify:manifest && npm run verify:engine && npm run typecheck && npm run lint",
    "verify:progression": "node scripts/verify-progression.mjs",
    "verify:achievements": "node scripts/verify-achievements.mjs",
    "verify:saves": "node scripts/verify-save-slots.mjs",
    "verify:hud": "node scripts/verify-hud.mjs",
    "verify:mobile": "node scripts/verify-mobile.mjs",
    "verify:manifest": "node scripts/verify-manifest.mjs",
    "verify:engine": "node scripts/verify-engine-api.mjs",
    "verify:multiplayer-api": "node scripts/verify-multiplayer-api.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "esbuild": "^0.28.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3"
  }
}
